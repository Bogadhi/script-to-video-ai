# ScriptToVideo AI Pipeline — Environment Variables
# Copy to .env and fill in your values

# ─── Required for LLM scene breakdown + metadata (gTTS fallback works without this)
OPENAI_API_KEY=sk-your-key-here

# ─── ElevenLabs TTS (optional — gTTS fallback works without this)
ELEVENLABS_API_KEY=sk_your_key_here
ELEVENLABS_VOICE_CALM=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_VOICE_ENERGETIC=AZnzlk1XvdvUeBnXmlld
ELEVENLABS_VOICE_DOCUMENTARY=ErXwobaYiN019PkySvjV

# ─── Pexels stock video (optional — solid-colour fallback works without this)
PEXELS_API_KEY=your_pexels_key_here

# ─── YouTube Upload (optional — only needed for publish feature)
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_secret
GOOGLE_REFRESH_TOKEN=1//your_refresh_token

# ─── Infrastructure
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=sqlite:///./video_automation.db
OUTPUT_DIR=./projects

# ─── Local music folder (optional) — put .mp3/.wav files here for background tracks
MUSIC_DIR=../music

# ─── Server
FRONTEND_URL=http://localhost:3000
PORT=8000
